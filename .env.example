# =============================================================================
# InsightQL - Environment Variables Example
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# =============================================================================
# Supabase (Required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_PROJECT_REF=your-project-ref

# =============================================================================
# GitHub Models / LLM (Required)
# =============================================================================
GITHUB_TOKEN=ghp_your_token_here
GITHUB_MODEL=gpt-4o
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com

# =============================================================================
# LangSmith Tracing (Optional but recommended)
# =============================================================================
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_your_key_here
LANGSMITH_PROJECT=InsightQL
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# Agent Configuration
# =============================================================================
AGENT_MAX_RETRIES=2
AGENT_CACHE_TTL_SECONDS=3600
AGENT_TIMEOUT_MS=30000

# =============================================================================
# Security & Rate Limiting
# =============================================================================
MAX_REQUESTS_PER_MINUTE=30
MAX_DAILY_REQUESTS=1000
MAX_TOKENS_PER_REQUEST=4000

# =============================================================================
# Voice / Speech-to-Text (Groq Whisper)
# =============================================================================
VOICE_ENABLED=true
VOICE_PROVIDER=groq
GROQ_API_KEY=gsk_your_groq_key_here
WHISPER_MODEL=whisper-large-v3-turbo
VOICE_LANGUAGE=es
MAX_AUDIO_DURATION_SECONDS=60

# =============================================================================
# Allowed RPC Functions (comma-separated allowlist)
# =============================================================================
ALLOWED_RPC_FUNCTIONS=rpc_catalog_summary,rpc_price_analysis,rpc_discount_analysis,rpc_availability_analysis,rpc_segment_price_comparison,rpc_category_price_comparison,rpc_subcategory_distribution,rpc_model_variety,rpc_price_distribution,rpc_size_distribution,rpc_best_deals,rpc_discount_products,rpc_count_by_filters,rpc_search_text,rpc_search_products_advanced,rpc_article_available_sizes

# =============================================================================
# Debug (set to false in production)
# =============================================================================
DEBUG=false
